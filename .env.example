# --- Lumen server ---

PORT=5050

# Optional. Defaults to gemini-2.0-flash. Each user pastes their own key in
# the app at /settings, but this name applies to all users. Try
# gemini-2.5-flash, gemini-1.5-flash, or gemini-2.0-flash-lite if needed.
# See https://ai.dev/rate-limit
GEMINI_MODEL=

# --- Auth ---

# Google OAuth credentials. Create a project + OAuth 2.0 Client ID at
# https://console.cloud.google.com/. Application type: "Web application".
# Authorized redirect URI: http://localhost:5050/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Where Google redirects back after sign-in. Must match the URI registered
# in your Google OAuth client. Defaults to ${CLIENT_ORIGIN}/api/auth/google/callback
# (i.e. http://localhost:5173/api/auth/google/callback in dev). It points at
# the Vite origin, not the API origin, so the session cookie gets set on the
# same origin the SPA runs on.
OAUTH_REDIRECT_URI=

# Where the server sends the user after successful login. Defaults to
# http://localhost:5173 (the Vite dev server).
CLIENT_ORIGIN=http://localhost:5173

# 32-byte hex secret for AES-256-GCM encryption of stored Gemini keys.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
