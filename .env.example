# --- Lumen server ---

PORT=5050

# Optional. Defaults to gemini-2.0-flash. Each user pastes their own key
# in the app at /settings.
GEMINI_MODEL=

# --- Auth ---

# Where the SPA runs. Magic-link emails point at ${CLIENT_ORIGIN}/auth/callback.
CLIENT_ORIGIN=http://localhost:5173

# 32-byte hex secret for AES-256-GCM encryption of stored Gemini keys + JWT
# signing. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Optional. If you want JWT signing to use a separate secret from encryption,
# set this. Otherwise it falls back to ENCRYPTION_KEY.
JWT_SECRET=

# --- Magic-link email delivery (Resend) ---

# Get a free API key at https://resend.com (3k emails/month, no card).
# When this is empty, the server logs the magic link to its terminal so
# you can iterate without setting up an email provider.
RESEND_API_KEY=

# What "From" address users see. The default uses Resend's shared dev
# domain (works without verifying anything). Switch to your own domain in
# prod, e.g. "Lumen <noreply@yourdomain.com>".
MAIL_FROM=Lumen <onboarding@resend.dev>

# --- Future: Google OAuth (kept dormant; not wired in this build) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
